# Database
DATABASE_URL="postgresql://user:password@localhost:5432/englishflow?schema=public"

# JWT
JWT_SECRET="your-super-secret-key-min-32-characters-here"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-characters-here"

# Server
PORT=3001
NODE_ENV=development

# Frontend
FRONTEND_URL="http://localhost:5173"

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Email Configuration
# For production, use SendGrid or AWS SES
# For development, use Ethereal (https://ethereal.email)

# SendGrid (Production - recommended)
SENDGRID_API_KEY=""

# OR AWS SES (Production - alternative)
AWS_SES_REGION=""
AWS_SES_ACCESS_KEY=""
AWS_SES_SECRET_KEY=""

# OR Ethereal (Development only - get credentials at https://ethereal.email)
ETHEREAL_USER=""
ETHEREAL_PASS=""

# Email settings
EMAIL_FROM="noreply@englishflow.com"
EMAIL_FROM_NAME="English Flow"
EMAIL_REPLY_TO="suporte@englishflow.com"
SUPPORT_EMAIL="suporte@englishflow.com"

# Stripe Payment Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret_here"

# Stripe Price IDs (create in Stripe Dashboard)
# Monthly subscription: R$ 39,90/month
STRIPE_PRICE_MONTHLY="price_1234567890monthly"
# Yearly subscription: R$ 399,90/year (2 months free)
STRIPE_PRICE_YEARLY="price_1234567890yearly"
