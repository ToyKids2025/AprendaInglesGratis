/**
 * SOCIAL MEDIA INTEGRATION SCHEMA
 */

model SocialAccount {
  id          String   @id @default(uuid())
  userId      String
  provider    String   // "facebook", "twitter", "instagram", "linkedin"
  providerId  String
  accessToken String   @db.Text
  autoShare   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  @@unique([userId, provider])
}

model SocialShare {
  id          String   @id @default(uuid())
  userId      String
  type        String   // "achievement", "level_up", "certificate"
  platforms   Json
  status      String   @default("success")
  createdAt   DateTime @default(now())
  
  @@index([userId])
}
