model UserFeedback {
  id String @id @default(uuid())
  userId String
  type String
  subject String
  message String @db.Text
  status String @default("pending")
  createdAt DateTime @default(now())
}

model ContentReport {
  id String @id @default(uuid())
  reporterId String
  contentType String
  contentId String
  reason String
  description String?
  status String @default("pending")
  createdAt DateTime @default(now())
}
