/**
 * ADVANCED ANALYTICS SCHEMA
 * User behavior tracking and platform metrics
 */

model UserAnalytics {
  id          String   @id @default(uuid())
  userId      String   @unique
  
  // Learning stats
  totalLessons     Int @default(0)
  totalPhrases     Int @default(0)
  totalQuizzes     Int @default(0)
  totalXP          Int @default(0)
  
  // Time stats
  totalMinutes     Int @default(0)
  avgSessionMinutes Float @default(0)
  
  // Engagement
  loginStreak      Int @default(0)
  longestStreak    Int @default(0)
  lastActiveAt     DateTime?
  
  // Performance
  avgQuizScore     Float @default(0)
  pronunciationAvg Float @default(0)
  
  updatedAt DateTime @updatedAt
  
  @@index([userId])
}

model PlatformMetrics {
  id          String   @id @default(uuid())
  date        DateTime @unique
  
  // Users
  dau         Int @default(0) // Daily Active Users
  mau         Int @default(0) // Monthly Active Users
  newUsers    Int @default(0)
  churnedUsers Int @default(0)
  
  // Engagement
  totalSessions    Int @default(0)
  avgSessionLength Float @default(0)
  totalLessons     Int @default(0)
  
  // Revenue
  mrr         Decimal @default(0) @db.Decimal(10, 2)
  newSubscriptions Int @default(0)
  canceledSubs     Int @default(0)
  
  createdAt DateTime @default(now())
  
  @@index([date])
}
