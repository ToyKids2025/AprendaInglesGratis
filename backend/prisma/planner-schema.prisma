model StudyPlan {
  id String @id @default(uuid())
  userId String
  goal String
  targetDate DateTime
  dailyMinutes Int
  createdAt DateTime @default(now())
  sessions StudySession[]
}

model StudySession {
  id String @id @default(uuid())
  planId String
  completedAt DateTime
  duration Int
  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}
